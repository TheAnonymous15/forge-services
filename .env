# ============================================================
# Database Configuration
#
# LOCAL DEVELOPMENT:  SQLite (no install required)
# PRODUCTION (cPanel): MySQL — create one DB via cPanel → MySQL Databases,
#                      then set DATABASE_URL below and USE_SINGLE_DATABASE=True
#
# cPanel MySQL example:
#   DATABASE_URL=mysql://cpanelusername_dbuser:yourpassword@localhost/cpanelusername_forgeforth
#
# All subsystems share the single database on shared hosting.
# ============================================================

# ============================================================
# Database Configuration
# ============================================================
# LOCAL DEV: SQLite (instant, no setup)
# PRODUCTION: cPanel PostgreSQL (always-on, no cold starts!)
# ============================================================

# --- Local dev (SQLite - FAST, no cold starts) ---
DATABASE_URL=sqlite:///db.sqlite3

# --- cPanel PostgreSQL (PRODUCTION - always-on, no cold starts!) ---
# Create database via cPanel → PostgreSQL Databases, then update:
# DATABASE_URL=postgresql://yepwpkjk_forge:YourPasswordHere@localhost/yepwpkjk_forgeforth

# --- Single database mode (all apps share one DB) ---
USE_SINGLE_DATABASE=True

# --- DISABLED: Neon PostgreSQL (30-50 second cold starts - NOT RECOMMENDED) ---
# DATABASE_URL=postgresql://neondb_owner:npg_AEZ67YwKmHOq@ep-steep-lab-a8388p7u-pooler.eastus2.azure.neon.tech/forgeforth_main?sslmode=require
# Cache
CACHE_URL=redis://localhost:6379/0



# Storage (local for dev, S3 for production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=forgeforth-media
AWS_S3_REGION_NAME=af-south-1

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://forgeforthafrica.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=django-db

# Sentry (error tracking)
SENTRY_DSN=

# Site
SITE_URL=http://localhost:8000
SITE_NAME=ForgeForth Africa

# Registration Settings
MIN_AGE=18

# Portal URLs (dev vs prod)
TALENT_PORTAL_URL_DEV=http://localhost:9003
TALENT_PORTAL_URL_PROD=https://talent.forgeforthafrica.com

