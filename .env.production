# ============================================================
# ForgeForth Africa - Production Environment Configuration
# ============================================================
# Copy this to .env on the production server and update values

# Environment
DJANGO_ENV=dev
DEBUG=False
SECRET_KEY=your-production-secret-key-here-change-this

# Allowed Hosts
ALLOWED_HOSTS=forgeforthafrica.com,www.forgeforthafrica.com

# Database (PostgreSQL with SSL)
DATABASE_URL=postgres://user:password@host:5432/dbname
DB_SSLMODE=verify-full
# DB_SSLCERT=/path/to/client.crt
# DB_SSLKEY=/path/to/client.key
# DB_SSLROOTCERT=/path/to/ca.crt

# Cache (Redis with SSL)
CACHE_URL=rediss://user:password@redis-host:6380/0
REDIS_SSL=True

# Storage (S3)
USE_S3=True
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=forgeforth-media
AWS_S3_REGION_NAME=af-south-1

# Security
CORS_ALLOWED_ORIGINS=https://forgeforthafrica.com,https://www.forgeforthafrica.com
CSRF_TRUSTED_ORIGINS=https://forgeforthafrica.com,https://www.forgeforthafrica.com

# SSL Settings
SECURE_SSL_REDIRECT=True
WEBSOCKET_SSL_REQUIRED=True

# Celery (Redis with SSL)
CELERY_BROKER_URL=rediss://user:password@redis-host:6380/1
CELERY_RESULT_BACKEND=django-db

# Sentry (error tracking)
SENTRY_DSN=your-sentry-dsn

# Site
SITE_URL=https://forgeforthafrica.com
SITE_NAME=ForgeForth Africa

