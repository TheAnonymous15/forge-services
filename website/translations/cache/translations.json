  "49afd896be692b5873246a1e8b6552e3": "Umqondiso",
  "e1c3fdd6f27e0db43c98d75f63cdbbf0": "I-Pan-African by Design",
  "2e6b2a956c85230747381885f32d962b": "Yakhelwe italente nganye, ishishini ngalinye, kuwo onke amazwe angama-54 aseAfrika.",
  "12fd33536381ce9fb8b9bde0d59e1e6c": "Konke",
