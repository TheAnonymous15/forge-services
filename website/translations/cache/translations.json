  "4b955048d37bb2daa59615de91b075bd": "I-30% yezimbiwa zoovimba behlabathi",
  "b6b44e86a48d97b31eb79134b83117f9": "UPhuhliso lweZakhono zoLuntu",
  "eccfe0a2ae9bd6c9f99e2ac66e213974": "Abantu abayi-1.4B, abaphakathi kweminyaka eyi-19",
  "5903f4409cac59432b365445bfa8fb9c": "ITALENTI-Ibonisiwe",
